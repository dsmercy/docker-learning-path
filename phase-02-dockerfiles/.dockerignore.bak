# Dependencies — never copy node_modules into the build context
node_modules/

# Vite build output — the Dockerfile rebuilds this inside the container
dist/

# Git metadata — not needed inside the image
.git/
.gitignore

# Editor / IDE artifacts
.vscode/
.idea/
*.suo
*.user

# OS noise
.DS_Store
Thumbs.db

# Local environment files — never bake secrets into an image
.env
.env.*

# Test output
coverage/

# Docker files themselves — not needed inside the image
Dockerfile
.dockerignore
